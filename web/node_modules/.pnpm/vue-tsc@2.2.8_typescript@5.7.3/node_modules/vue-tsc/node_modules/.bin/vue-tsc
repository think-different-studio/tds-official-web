#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/proc/cygdrive/e/Desktop/TDS_Homepage/web/node_modules/.pnpm/vue-tsc@2.2.8_typescript@5.7.3/node_modules/vue-tsc/node_modules:/proc/cygdrive/e/Desktop/TDS_Homepage/web/node_modules/.pnpm/vue-tsc@2.2.8_typescript@5.7.3/node_modules:/proc/cygdrive/e/Desktop/TDS_Homepage/web/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/proc/cygdrive/e/Desktop/TDS_Homepage/web/node_modules/.pnpm/vue-tsc@2.2.8_typescript@5.7.3/node_modules/vue-tsc/node_modules:/proc/cygdrive/e/Desktop/TDS_Homepage/web/node_modules/.pnpm/vue-tsc@2.2.8_typescript@5.7.3/node_modules:/proc/cygdrive/e/Desktop/TDS_Homepage/web/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../bin/vue-tsc.js" "$@"
else
  exec node  "$basedir/../../bin/vue-tsc.js" "$@"
fi
